<div class="page-container">
  <div class="success-state">
    <div class="success-icon">✓</div>
    <h1 class="success-title">Thank you for your order!</h1>
    <p class="success-sub">Order <strong>{{order.id}}</strong> placed at {{order.placedAt}}</p>
    <p class="success-sub">Confirmation sent to <strong>{{order.email}}</strong></p>

    <div class="success-card">
      <h2 class="summary-title">Order Summary</h2>
      {{#each order.items}}
      <div class="order-line">
        <span class="order-line-name">{{product.name}} <span class="order-line-qty">×{{qty}}</span></span>
        <span class="order-line-price">${{subtotal}}</span>
      </div>
      {{/each}}
      <div class="summary-divider"></div>
      <div class="summary-row summary-total"><span>Total paid</span><span>${{order.total}}</span></div>
    </div>

    <a href="/" class="btn-primary">Continue Shopping</a>
  </div>
</div>
