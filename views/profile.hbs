<div class="page-container">
  <div class="page-header">
    <div>
      <a href="/" class="back-link">← Back to Shop</a>
      <h1 class="page-title">My Profile</h1>
    </div>
  </div>

  <div class="auth-card" style="margin-top:2rem">
    <div class="auth-panel">
      <div class="profile-avatar">{{user.name}}</div>
      <p class="hero-eyebrow">Logged in as</p>
      <h2 class="hero-title" style="font-size:1.8rem">{{user.name}}</h2>
      <p class="hero-sub">{{user.email}}</p>
      <p class="hero-sub" style="margin-top:.5rem">
        <span class="profile-role">{{user.role}}</span>
      </p>
    </div>

    <div class="auth-panel auth-form-card">
      {{#if success}}<p class="alert-success" style="margin-bottom:1rem">✅ Profile updated!</p>{{/if}}
      {{#if error}}<p class="alert-error" style="margin-bottom:1rem">{{error}}</p>{{/if}}

      <form method="POST" action="/profile">
        <div class="form-group">
          <label class="form-label">Full Name</label>
          <input type="text" name="name" value="{{user.name}}" class="form-input" required>
        </div>
        <div class="form-group">
          <label class="form-label">Email</label>
          <input type="text" value="{{user.email}}" class="form-input" disabled style="opacity:.6">
        </div>
        <div class="form-group">
          <label class="form-label">Shipping Address</label>
          <input type="text" name="address" value="{{user.address}}" class="form-input" required>
        </div>
        <div class="form-group">
          <label class="form-label">New Password <span style="font-weight:400;font-size:.8rem">(leave blank to keep current)</span></label>
          <input type="password" name="password" class="form-input" placeholder="New password">
        </div>
        <div class="form-group">
          <label class="form-label">Confirm Password</label>
          <input type="password" name="confirmPassword" class="form-input" placeholder="Confirm new password">
        </div>
        <div class="profile-actions">
          <button type="submit" class="btn-primary">Save Changes</button>
          <a href="/orders" class="btn-ghost">Order History</a>
          <a href="/logout" class="btn-ghost">Logout</a>
        </div>
      </form>
    </div>
  </div>
</div>
